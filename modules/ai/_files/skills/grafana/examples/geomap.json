{
  "apiVersion": "dashboard.grafana.app/v2beta1",
  "kind": "Dashboard",
  "metadata": {
    "name": "example-geomap",
    "labels": {},
    "annotations": {}
  },
  "spec": {
    "elements": {
      "panel-geomap": {
        "kind": "Panel",
        "spec": {
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "group": "grafana",
                      "kind": "DataQuery",
                      "spec": {
                        "editorMode": "builder",
                        "expr": "sum by(geohash) (rate(http_requests_total[$__rate_interval]))",
                        "legendFormat": "sum(rate)",
                        "range": true
                      },
                      "version": "v0"
                    },
                    "refId": "A"
                  }
                }
              ],
              "queryOptions": {
                "maxDataPoints": 500
              },
              "transformations": [
                {
                  "kind": "labelsToFields",
                  "spec": {
                    "id": "labelsToFields",
                    "options": {
                      "mode": "columns"
                    }
                  }
                }
              ]
            }
          },
          "description": "Geohash-based heatmap layer showing request rate by location. The PromQL query preserves the geohash label via 'by(geohash)', then 'Labels to Fields' materializes it into a column so the Geomap panel can decode it.",
          "id": 1,
          "links": [],
          "title": "Request Rate by Location",
          "vizConfig": {
            "group": "geomap",
            "kind": "VizConfig",
            "spec": {
              "fieldConfig": {
                "defaults": {
                  "color": {
                    "mode": "thresholds"
                  },
                  "thresholds": {
                    "mode": "absolute",
                    "steps": [
                      { "color": "green", "value": 0 },
                      { "color": "red", "value": 80 }
                    ]
                  },
                  "unit": "cps"
                },
                "overrides": []
              },
              "options": {
                "basemap": {
                  "config": {},
                  "name": "Layer 0",
                  "type": "default"
                },
                "controls": {
                  "mouseWheelZoom": true,
                  "showAttribution": true,
                  "showDebug": false,
                  "showMeasure": false,
                  "showScale": false,
                  "showZoom": true
                },
                "layers": [
                  {
                    "config": {
                      "blur": 15,
                      "radius": 5,
                      "weight": {
                        "fixed": 1,
                        "max": 1,
                        "min": 0
                      }
                    },
                    "name": "Heatmap",
                    "tooltip": true,
                    "type": "heatmap"
                  }
                ],
                "tooltip": {
                  "mode": "details"
                },
                "view": {
                  "allLayers": true,
                  "id": "coords",
                  "lat": 50,
                  "lon": 10,
                  "zoom": 5
                }
              }
            },
            "version": "12.3.0"
          }
        }
      }
    },
    "layout": {
      "kind": "GridLayout",
      "spec": {
        "items": [
          {
            "kind": "GridLayoutItem",
            "spec": {
              "element": {
                "kind": "ElementReference",
                "name": "panel-geomap"
              },
              "height": 16,
              "width": 24,
              "x": 0,
              "y": 0
            }
          }
        ]
      }
    },
    "links": [],
    "preload": false,
    "tags": [],
    "timeSettings": {
      "from": "now-24h",
      "to": "now",
      "timezone": "browser"
    },
    "title": "Geomap Example",
    "variables": []
  }
}
