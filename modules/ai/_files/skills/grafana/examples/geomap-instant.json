{
  "apiVersion": "dashboard.grafana.app/v2beta1",
  "kind": "Dashboard",
  "metadata": {
    "name": "example-geomap-instant",
    "labels": {},
    "annotations": {}
  },
  "spec": {
    "elements": {
      "panel-geomap-heatmap": {
        "kind": "Panel",
        "spec": {
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "group": "grafana",
                      "kind": "DataQuery",
                      "spec": {
                        "editorMode": "builder",
                        "exemplar": false,
                        "expr": "sum by(geohash) (app_requests_total{env=\"production\"})",
                        "format": "table",
                        "instant": true,
                        "legendFormat": "__auto",
                        "range": false
                      },
                      "version": "v0"
                    },
                    "refId": "A"
                  }
                }
              ],
              "queryOptions": {}
            }
          },
          "description": "Geohash heatmap without transformations. The trick: use 'sum by(geohash)' with 'instant: true' and 'format: table'. The instant+table combination returns a flat table with a geohash column that the Geomap panel decodes directly — no 'Labels to Fields' transformation needed.",
          "id": 1,
          "links": [],
          "title": "Requests per Region",
          "vizConfig": {
            "group": "geomap",
            "kind": "VizConfig",
            "spec": {
              "fieldConfig": {
                "defaults": {
                  "color": {
                    "mode": "thresholds"
                  },
                  "custom": {
                    "hideFrom": {
                      "legend": false,
                      "tooltip": false,
                      "viz": false
                    }
                  },
                  "mappings": [],
                  "thresholds": {
                    "mode": "absolute",
                    "steps": [
                      { "color": "green", "value": null },
                      { "color": "red", "value": 80 }
                    ]
                  }
                },
                "overrides": []
              },
              "options": {
                "basemap": {
                  "config": {},
                  "name": "Layer 0",
                  "noRepeat": false,
                  "type": "default"
                },
                "controls": {
                  "mouseWheelZoom": true,
                  "showAttribution": false,
                  "showDebug": false,
                  "showMeasure": false,
                  "showScale": true,
                  "showZoom": true
                },
                "layers": [
                  {
                    "config": {
                      "blur": 20,
                      "radius": 19,
                      "weight": {
                        "field": "Value",
                        "fixed": 1,
                        "max": 1,
                        "min": 0
                      }
                    },
                    "filterData": {
                      "id": "byRefId",
                      "options": "A"
                    },
                    "layer-tooltip": false,
                    "location": {
                      "mode": "auto"
                    },
                    "name": "Heatmap",
                    "tooltip": true,
                    "type": "heatmap"
                  }
                ],
                "tooltip": {
                  "mode": "details"
                },
                "view": {
                  "allLayers": true,
                  "id": "coords",
                  "lat": 51,
                  "lon": 10,
                  "noRepeat": false,
                  "zoom": 5
                }
              }
            },
            "version": "12.3.0"
          }
        }
      }
    },
    "layout": {
      "kind": "GridLayout",
      "spec": {
        "items": [
          {
            "kind": "GridLayoutItem",
            "spec": {
              "element": {
                "kind": "ElementReference",
                "name": "panel-geomap-heatmap"
              },
              "height": 8,
              "width": 12,
              "x": 0,
              "y": 0
            }
          }
        ]
      }
    },
    "links": [],
    "preload": false,
    "tags": [],
    "timeSettings": {
      "from": "now-24h",
      "to": "now",
      "timezone": "browser"
    },
    "title": "Geomap Instant Heatmap Example",
    "variables": []
  }
}
